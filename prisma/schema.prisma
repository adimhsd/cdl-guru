generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  level         Level?
  role          Role      @default(GURU)
  createdAt     DateTime  @default(now())
  
  sessions      Session[]
  accounts      Account[]
  testResults   TestResult[]
  interactions  Interaction[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model TestResult {
  id           String    @id @default(cuid())
  userId       String
  type         TestType
  score        Int
  level        Level
  completedAt  DateTime  @default(now())
  answers      TestAnswer[]

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model TestAnswer {
  id              String     @id @default(cuid())
  testResultId    String
  questionId      Int
  selectedAnswer  String
  isCorrect       Boolean
  confidenceScore Int        // 1–5
  createdAt       DateTime   @default(now())
  testResult      TestResult @relation(fields: [testResultId], references: [id])
}

model Interaction {
  id          String   @id @default(cuid())
  userId      String
  userInput   String   @db.Text
  aiOutput    String   @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TestType {
  PRE_TEST
  POST_TEST
}

enum Role {
  GURU
  ADMIN
}
