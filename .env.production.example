# ==========================================
# Template Environment Variable Production
# Copy file ini menjadi .env di server VPS Anda
# ==========================================

# -- Konfigurasi Database PostgreSQL (Untuk Docker Compose) --
# Variabel ini akan dipakai oleh service 'db' di docker-compose
POSTGRES_USER=cdl_admin
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=cdl_production

# URL koneksi database yang akan dipakai oleh Prisma ORM di service 'app'
# Ubah `your_secure_db_password` sesuai dengan POSTGRES_PASSWORD di atas
DATABASE_URL="postgresql://cdl_admin:your_secure_db_password@db:5432/cdl_production?schema=public"

# -- Konfigurasi NextAuth --
# URL aplikasi yang terekspos ke internet (Subdomain Cloudflare Anda)
NEXTAUTH_URL="https://cdl.adi-muhamad.my.id"

# Secret untuk NextAuth (Generate menggunakan `openssl rand -base64 32` di terminal VPS Anda)
NEXTAUTH_SECRET="generate_a_random_secret_key_here"

# -- Konfigurasi OpenAI API --
# API Key ChatGPT untuk fitur AI tutor
OPENAI_API_KEY="sk-your-openai-api-key-here"

# -- Konfigurasi Cloudflare Tunnel --
# Token yang didapatkan dari dashboard Cloudflare Zero Trust saat membuat tunnel baru
CLOUDFLARE_TUNNEL_TOKEN="eyJh..."

# ==========================================
# -- Konfigurasi PWA Push Notifications --
# Generate dengan menjalankan: npm run generate-vapid
# ⚠️ PENTING: Generate SEKALI SAJA. Jika diulang, semua subscription akan hilang.
# ==========================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_vapid_key_here
VAPID_PRIVATE_KEY=your_private_vapid_key_here
VAPID_MAILTO=mailto:admin@cdl.adi-muhamad.my.id
